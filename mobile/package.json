{
  "name": "crm-mobile",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "build:dev-api": "npm run build:dev",
    "preview": "vite preview",
    "cap:sync": "npm run build && npx cap sync android",
    "android": "npm run build && npx cap sync android && npx cap open android",
    "apk": "npm run apk:prod",
    "apk:prod": "npm run build && npx cap sync android && cd android && gradlew.bat assembleProdDebug",
    "apk:dev": "npm run build:dev && npx cap sync android && cd android && gradlew.bat assembleDevDebug",
    "apk:dev-api": "npm run apk:dev",
    "apk:desktop": "node ./scripts/copy-apk-to-desktop.mjs prod",
    "apk:desktop:prod": "node ./scripts/copy-apk-to-desktop.mjs prod",
    "apk:desktop:dev": "node ./scripts/copy-apk-to-desktop.mjs dev"
  },
  "dependencies": {
    "@capacitor/core": "^6.1.2",
    "@capacitor/geolocation": "^6.1.1",
    "lucide-react": "0.487.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router": "7.13.0",
    "tw-animate-css": "1.3.8"
  },
  "devDependencies": {
    "@capacitor/android": "^6.1.2",
    "@capacitor/cli": "^6.2.1",
    "@tailwindcss/vite": "4.1.12",
    "@vitejs/plugin-react": "4.7.0",
    "cross-env": "^7.0.3",
    "tailwindcss": "4.1.12",
    "typescript": "5.7.2",
    "vite": "6.3.5"
  },
  "capacitor": {
    "platforms": [
      "android"
    ]
  }
}
